<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Default configuration that applies to all connections -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system Certificate Authorities -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Domain-specific configurations can be added here if needed -->
    <!-- Example for a specific domain (not needed for this app):
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">hex-zero.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
    -->
</network-security-config>
