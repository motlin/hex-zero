<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude all app data from cloud backup -->
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <!-- Allow game progress to transfer to new devices -->
        <include domain="sharedpref" />
        <include domain="database" />
        <include domain="file" />
    </device-transfer>
</data-extraction-rules>
