{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"strictNullChecks": true,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"types": ["react", "react-native"]
	},
	"include": [
		"src/**/*",
		"tests/**/*",
		"vite.config.ts",
		"vitest.config.ts",
		"eslint.config.ts",
		"App.tsx",
		"app.json"
	],
	"exclude": [
		"node_modules",
		"babel.config.cjs",
		"metro.config.cjs",
		"jest.config.js",
		"src/hex-zero.ts",
		"src/canvas/**/*",
		"src/renderer/**/*",
		"src/canvas-utils.ts",
		"src/canvas-utils.test.ts",
		"**/*.test.ts",
		"**/*.test.tsx"
	]
}
