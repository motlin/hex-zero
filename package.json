{
	"name": "hex-zero",
	"version": "1.0.0",
	"description": "Hex Zero is a browser-based hexagonal puzzle game where players place septomino pieces to reduce all board tiles to zero.",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"preview": "vite preview",
		"build": "vite build",
		"lint": "eslint . --fix",
		"format": "biome format --write . && prettier --write .",
		"ci:eslint": "eslint . --format json --output-file eslint_report.json",
		"ci:prettier": "prettier --check \"src/**/*.{js,ts,css,md,json}\"",
		"ci:biome": "biome format .",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"start": "expo start",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"web": "expo start --web"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/motlin/hex-zero.git"
	},
	"keywords": [],
	"author": "",
	"bugs": {
		"url": "https://github.com/motlin/hex-zero/issues"
	},
	"homepage": "https://github.com/motlin/hex-zero#readme",
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@eslint/js": "^10.0.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.20",
		"@types/canvas-confetti": "^1.9.0",
		"@types/node": "^25.5.2",
		"@vitest/ui": "^4.1.3",
		"babel-preset-expo": "^13.2.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"jiti": "^2.6.1",
		"jsdom": "^29.0.2",
		"prettier": "^3.8.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@react-native-async-storage/async-storage": "^2.1.2",
		"@shopify/react-native-skia": "^2.0.5",
		"@types/react": "~19.0.10",
		"@types/react-native": "^0.72.8",
		"canvas-confetti": "^1.9.4",
		"expo": "^53.0.12",
		"expo-constants": "~17.1.6",
		"expo-device": "~7.1.4",
		"expo-status-bar": "~2.2.3",
		"react": "^19.0.0",
		"react-native": "^0.79.4",
		"react-native-confetti-cannon": "^1.5.2",
		"react-native-gesture-handler": "~2.24.0",
		"react-native-reanimated": "~3.19.1"
	}
}
