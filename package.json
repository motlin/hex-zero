{
	"name": "hex-zero",
	"version": "1.0.0",
	"description": "Hex Zero is a browser-based hexagonal puzzle game where players place septomino pieces to reduce all board tiles to zero.",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"preview": "vite preview",
		"build": "vite build",
		"lint": "eslint . --fix",
		"format": "biome format --write . && prettier --write .",
		"ci:eslint": "eslint . --format json --output-file eslint_report.json",
		"ci:prettier": "prettier --check \"src/**/*.{js,ts,css,md,json}\"",
		"ci:biome": "biome format .",
		"ci:typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"cap:sync": "npm run build && npx cap sync",
		"cap:copy": "npm run build && npx cap copy",
		"cap:update": "npx cap update",
		"ios:build": "npm run cap:sync && npx cap open ios",
		"ios:run": "npm run cap:sync && npx cap run ios",
		"android:build": "npm run cap:sync && npx cap open android",
		"android:run": "npm run cap:sync && npx cap run android",
		"generate:icons": "node scripts/generate-app-icons.js",
		"generate:launch": "node scripts/generate-launch-screens.js",
		"generate:assets": "npm run generate:icons && npm run generate:launch",
		"version:update": "node scripts/update-version.js",
		"version:patch": "node scripts/update-version.js patch",
		"version:minor": "node scripts/update-version.js minor",
		"version:major": "node scripts/update-version.js major",
		"build:ios": "node scripts/build-ios.js",
		"build:android": "node scripts/build-android.js",
		"test:platforms": "node scripts/test-all-platforms.js",
		"sync": "npm run build && npx cap sync",
		"sync:ios": "npm run build && npx cap sync ios",
		"sync:android": "npm run build && npx cap sync android",
		"screenshots": "node scripts/generate-screenshots.js",
		"screenshots:android": "node scripts/generate-android-screenshots.js",
		"play-store:graphics": "node scripts/generate-feature-graphic.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/motlin/hex-zero.git"
	},
	"keywords": [],
	"author": "",
	"bugs": {
		"url": "https://github.com/motlin/hex-zero/issues"
	},
	"homepage": "https://github.com/motlin/hex-zero#readme",
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@eslint/js": "^10.0.1",
		"@testing-library/dom": "^10.4.1",
		"@types/canvas-confetti": "^1.9.0",
		"@types/node": "^25.5.2",
		"@vitest/ui": "^4.1.3",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"jiti": "^2.6.1",
		"jsdom": "^29.0.2",
		"prettier": "^3.8.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@capacitor/android": "^7.3.0",
		"@capacitor/app": "^7.0.1",
		"@capacitor/cli": "^7.3.0",
		"@capacitor/core": "^7.3.0",
		"@capacitor/device": "^7.0.1",
		"@capacitor/haptics": "^7.0.1",
		"@capacitor/ios": "^7.3.0",
		"@capacitor/share": "^7.0.1",
		"@capacitor/status-bar": "^7.0.1",
		"canvas-confetti": "^1.9.4"
	}
}
